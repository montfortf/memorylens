{
  "title": "MemoryLens \u2014 Cost",
  "description": "MemoryLens cost attribution: cost by agent, session, and operation type. Token usage (in/out) over time. Top spenders by session. Uses @memorylens.cost_usd, @memorylens.tokens_in, @memorylens.tokens_out.",
  "layout_type": "ordered",
  "tags": ["memorylens"],
  "widgets": [
    {
      "definition": {
        "title": "Cost by Agent (Last 24h)",
        "title_size": "16",
        "title_align": "left",
        "type": "toplist",
        "requests": [
          {
            "q": "sum:memorylens.cost_usd{*} by {@memorylens.agent_id}.rollup(sum, 86400)",
            "style": { "palette": "warm" }
          }
        ]
      },
      "layout": { "x": 0, "y": 0, "width": 4, "height": 3 }
    },
    {
      "definition": {
        "title": "Cost Over Time by Session",
        "title_size": "16",
        "title_align": "left",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:memorylens.cost_usd{*} by {@memorylens.session_id}.as_rate()",
            "display_type": "area",
            "style": { "palette": "dog_classic", "line_type": "solid", "line_width": "normal" }
          }
        ],
        "yaxis": { "min": "0" },
        "legend": { "type": "automatic" }
      },
      "layout": { "x": 4, "y": 0, "width": 8, "height": 3 }
    },
    {
      "definition": {
        "title": "Cost by Operation Type",
        "title_size": "16",
        "title_align": "left",
        "type": "toplist",
        "requests": [
          {
            "q": "sum:memorylens.cost_usd{*} by {@memorylens.operation}.rollup(sum, 86400)",
            "style": { "palette": "purple" }
          }
        ]
      },
      "layout": { "x": 0, "y": 3, "width": 4, "height": 3 }
    },
    {
      "definition": {
        "title": "Token Usage Over Time (In + Out)",
        "title_size": "16",
        "title_align": "left",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:memorylens.tokens_in{*}.as_rate()",
            "display_type": "area",
            "style": { "palette": "cool" },
            "metadata": [{ "expression": "sum:memorylens.tokens_in{*}.as_rate()", "alias_name": "Tokens In" }]
          },
          {
            "q": "sum:memorylens.tokens_out{*}.as_rate()",
            "display_type": "area",
            "style": { "palette": "warm" },
            "metadata": [{ "expression": "sum:memorylens.tokens_out{*}.as_rate()", "alias_name": "Tokens Out" }]
          }
        ],
        "yaxis": { "min": "0" }
      },
      "layout": { "x": 4, "y": 3, "width": 8, "height": 3 }
    },
    {
      "definition": {
        "title": "Top Spenders by Session",
        "title_size": "16",
        "title_align": "left",
        "type": "query_table",
        "requests": [
          {
            "q": "sum:memorylens.cost_usd{*} by {@memorylens.session_id,@memorylens.agent_id}.rollup(sum, 86400)",
            "alias": "Cost (USD)",
            "limit": 10,
            "order": "desc",
            "aggregator": "sum",
            "cell_display_mode": ["bar"],
            "conditional_formats": [
              { "comparator": ">", "value": 10, "palette": "white_on_red" },
              { "comparator": ">", "value": 1, "palette": "white_on_yellow" },
              { "comparator": "<=", "value": 1, "palette": "white_on_green" }
            ]
          }
        ],
        "has_search_bar": "auto"
      },
      "layout": { "x": 0, "y": 6, "width": 12, "height": 4 }
    }
  ]
}
