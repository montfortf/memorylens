{
  "title": "MemoryLens \u2014 Drift",
  "description": "MemoryLens memory drift detection: drift events over time, score distributions, top drifting entities, and drift rate by agent. Uses @memorylens.drift_score, @memorylens.drift_detected, @memorylens.memory_key.",
  "layout_type": "ordered",
  "tags": ["memorylens"],
  "widgets": [
    {
      "definition": {
        "title": "Drift Events Over Time",
        "title_size": "16",
        "title_align": "left",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.memorylens.request.hits{@memorylens.drift_detected:true}.as_rate() * 60",
            "display_type": "line",
            "style": { "palette": "warm", "line_type": "solid", "line_width": "normal" }
          }
        ],
        "yaxis": { "min": "0" },
        "markers": [
          { "value": "y = 5", "display_type": "warning dashed", "label": "5/min threshold" },
          { "value": "y = 20", "display_type": "error dashed", "label": "20/min critical" }
        ]
      },
      "layout": { "x": 0, "y": 0, "width": 8, "height": 3 }
    },
    {
      "definition": {
        "title": "Drift Rate (% of Spans)",
        "title_size": "16",
        "title_align": "left",
        "type": "query_value",
        "requests": [
          {
            "q": "sum:trace.memorylens.request.hits{@memorylens.drift_detected:true}.as_count() / sum:trace.memorylens.request.hits{*}.as_count() * 100",
            "aggregator": "last",
            "conditional_formats": [
              { "comparator": "<", "value": 5, "palette": "white_on_green" },
              { "comparator": "<", "value": 15, "palette": "white_on_yellow" },
              { "comparator": ">=", "value": 15, "palette": "white_on_red" }
            ]
          }
        ],
        "autoscale": true,
        "custom_unit": "%",
        "precision": 1,
        "text_align": "center"
      },
      "layout": { "x": 8, "y": 0, "width": 4, "height": 3 }
    },
    {
      "definition": {
        "title": "Drift Score Distribution",
        "title_size": "16",
        "title_align": "left",
        "type": "distribution",
        "requests": [
          {
            "q": "avg:memorylens.drift_score{@memorylens.drift_detected:true} by {@memorylens.agent_id}",
            "style": { "palette": "warm" }
          }
        ]
      },
      "layout": { "x": 0, "y": 3, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Drift Rate by Agent",
        "title_size": "16",
        "title_align": "left",
        "type": "toplist",
        "requests": [
          {
            "q": "sum:trace.memorylens.request.hits{@memorylens.drift_detected:true} by {@memorylens.agent_id}.as_count() / sum:trace.memorylens.request.hits{*} by {@memorylens.agent_id}.as_count() * 100",
            "style": { "palette": "warm" },
            "conditional_formats": [
              { "comparator": "<", "value": 5, "palette": "white_on_green" },
              { "comparator": "<", "value": 15, "palette": "white_on_yellow" },
              { "comparator": ">=", "value": 15, "palette": "white_on_red" }
            ]
          }
        ]
      },
      "layout": { "x": 6, "y": 3, "width": 6, "height": 3 }
    },
    {
      "definition": {
        "title": "Top Drifting Entities",
        "title_size": "16",
        "title_align": "left",
        "type": "query_table",
        "requests": [
          {
            "q": "max:memorylens.drift_score{@memorylens.drift_detected:true} by {@memorylens.memory_key,@memorylens.agent_id}",
            "alias": "Drift Score",
            "limit": 20,
            "order": "desc",
            "aggregator": "max",
            "cell_display_mode": ["bar"],
            "conditional_formats": [
              { "comparator": ">=", "value": 0.8, "palette": "white_on_red" },
              { "comparator": ">=", "value": 0.5, "palette": "white_on_yellow" },
              { "comparator": "<", "value": 0.5, "palette": "white_on_green" }
            ]
          }
        ],
        "has_search_bar": "auto"
      },
      "layout": { "x": 0, "y": 6, "width": 12, "height": 4 }
    }
  ]
}
