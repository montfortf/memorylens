{
  "title": "MemoryLens \u2014 Cost",
  "uid": "memorylens-cost",
  "tags": ["memorylens"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Cost by Agent",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (memorylens_agent_id) (increase(memorylens_cost_usd_total{service_name=\"memorylens\"}[24h]))",
          "legendFormat": "{{memorylens_agent_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 2,
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (memorylens_session_id) (rate(memorylens_cost_usd_total{service_name=\"memorylens\"}[5m]) * 3600)",
          "legendFormat": "{{memorylens_session_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "mean"] }
      }
    },
    {
      "id": 3,
      "title": "Cost by Operation Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (memorylens_operation) (increase(memorylens_cost_usd_total{service_name=\"memorylens\"}[24h]))",
          "legendFormat": "{{memorylens_operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] }
      }
    },
    {
      "id": 4,
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(memorylens_tokens_in_total{service_name=\"memorylens\"}[5m]) * 60)",
          "legendFormat": "Tokens In",
          "refId": "A"
        },
        {
          "expr": "sum(rate(memorylens_tokens_out_total{service_name=\"memorylens\"}[5m]) * 60)",
          "legendFormat": "Tokens Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Tokens In" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Tokens Out" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Top Spenders by Session",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, sum by (memorylens_session_id, memorylens_agent_id) (increase(memorylens_cost_usd_total{service_name=\"memorylens\"}[24h])))",
          "legendFormat": "{{memorylens_session_id}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "memorylens_session_id" },
            "properties": [{ "id": "displayName", "value": "Session ID" }]
          },
          {
            "matcher": { "id": "byName", "options": "memorylens_agent_id" },
            "properties": [{ "id": "displayName", "value": "Agent ID" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "Cost (USD)" }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Cost (USD)", "desc": true }]
      }
    }
  ]
}
