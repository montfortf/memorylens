{
  "title": "MemoryLens \u2014 Drift",
  "uid": "memorylens-drift",
  "tags": ["memorylens"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Drift Events Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"memorylens\", memorylens_drift_detected=\"true\"}[5m]) * 60)",
          "legendFormat": "Drift Events/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Drift Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "memorylens_drift_score_bucket{service_name=\"memorylens\", memorylens_drift_detected=\"true\"}",
          "legendFormat": "Drift Score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "unit": "short",
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "bucketSize": "auto",
        "fillOpacity": 80,
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 3,
      "title": "Top Drifting Entities",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "topk(20, max by (memorylens_memory_key, memorylens_agent_id) (memorylens_drift_score{service_name=\"memorylens\", memorylens_drift_detected=\"true\"}))",
          "legendFormat": "{{memorylens_memory_key}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "memorylens_memory_key" },
            "properties": [{ "id": "displayName", "value": "Memory Key" }]
          },
          {
            "matcher": { "id": "byName", "options": "memorylens_agent_id" },
            "properties": [{ "id": "displayName", "value": "Agent ID" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "Drift Score" }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Drift Score", "desc": true }]
      }
    },
    {
      "id": 4,
      "title": "Drift Rate by Agent",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (memorylens_agent_id) (rate(traces_spanmetrics_calls_total{service_name=\"memorylens\", memorylens_drift_detected=\"true\"}[5m])) / sum by (memorylens_agent_id) (rate(traces_spanmetrics_calls_total{service_name=\"memorylens\"}[5m])) * 100",
          "legendFormat": "{{memorylens_agent_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    }
  ]
}
