{
  "title": "MemoryLens \u2014 Operations",
  "uid": "memorylens-operations",
  "tags": ["memorylens"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Span Count by Operation",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (memorylens_operation) (rate(traces_spanmetrics_calls_total{service_name=\"memorylens\"}[5m]))",
          "legendFormat": "{{memorylens_operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 2,
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"memorylens\", status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum(rate(traces_spanmetrics_calls_total{service_name=\"memorylens\"}[5m])) * 100",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Latency P50 / P95 / P99 by Operation",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, memorylens_operation) (rate(traces_spanmetrics_latency_bucket{service_name=\"memorylens\"}[5m])))",
          "legendFormat": "P50 {{memorylens_operation}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, memorylens_operation) (rate(traces_spanmetrics_latency_bucket{service_name=\"memorylens\"}[5m])))",
          "legendFormat": "P95 {{memorylens_operation}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, memorylens_operation) (rate(traces_spanmetrics_latency_bucket{service_name=\"memorylens\"}[5m])))",
          "legendFormat": "P99 {{memorylens_operation}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 4,
      "title": "Throughput (Spans per Minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (memorylens_operation) (rate(traces_spanmetrics_calls_total{service_name=\"memorylens\"}[1m]) * 60)",
          "legendFormat": "{{memorylens_operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 5,
      "title": "Top Agents by Span Count",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, sum by (memorylens_agent_id) (rate(traces_spanmetrics_calls_total{service_name=\"memorylens\"}[5m])))",
          "legendFormat": "{{memorylens_agent_id}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "memorylens_agent_id" },
            "properties": [{ "id": "displayName", "value": "Agent ID" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "Spans/s" }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Spans/s", "desc": true }]
      }
    }
  ]
}
