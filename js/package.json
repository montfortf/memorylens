{
  "name": "memorylens",
  "version": "0.1.0",
  "description": "Observability and debugging for AI agent memory systems",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./integrations/langchain": {
      "types": "./dist/integrations/langchain/index.d.ts",
      "import": "./dist/integrations/langchain/index.js",
      "require": "./dist/integrations/langchain/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "@opentelemetry/sdk-trace-base": "^1.20.0"
  },
  "peerDependencies": {
    "langchain": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "langchain": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
